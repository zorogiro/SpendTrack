{
  "expo": {
    "name": "SpendTrack",
    "slug": "spendtrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "spendtrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spendtrack.app"
    },
    "android": {
      "package": "com.spendtrack.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
